{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/main.ts", "src/preload.ts", "forge.env.d.ts"]
}